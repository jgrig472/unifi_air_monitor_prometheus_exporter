# Copy to .env and fill in. .env is gitignored.

# UniFi Protect controller hostname (no scheme, no path)
PROTECT_HOST=dragon.home.co

# Local Protect account — recommend a dedicated Viewer-role, Protect-only
# account, since the air-quality readings require cookie-session auth and
# can't be scoped to a single device or read-only API key.
PROTECT_USER=
PROTECT_PASS=

# Self-signed cert on the controller -> false
PROTECT_VERIFY_TLS=false

EXPORTER_PORT=9840
